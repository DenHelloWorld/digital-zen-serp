{
  "manifest_version": 3,
  "name": "Digital Zen SERP",
  "version": "1.0.1",
  "description": "Serp",
  "permissions": [
    "alarms",
    "declarativeNetRequest",
    "storage",
    "unlimitedStorage",
    "activeTab",
    "identity",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Digital Zen SERP"
  },
  "web_accessible_resources": [
    {
      "resources": ["index.html", "content.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
