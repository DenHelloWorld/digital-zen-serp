{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2020",
    "outDir": "dist/browser",
    "rootDir": "src",
    "strict": true,
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true
  },
  "files": ["src/background.ts", "src/extension-config.ts"],
  "tsc-alias": {
    "verbose": false,
    "resolveFullPaths": true,
    "fileExtensions": {
      "inputGlob": "{js,jsx,mjs}",
      "outputCheck": ["js", "json", "jsx", "mjs"]
    }
  }
}
